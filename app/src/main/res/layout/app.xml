<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">
    <ViewFlipper
        android:id="@+id/app_initial_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/auth_fragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:name="com.namimeow.roleworld.fragment.AuthFragment"/>
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/greeting_fragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:name="com.namimeow.roleworld.fragment.GreetingFragment"/>
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/app_fragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:name="com.namimeow.roleworld.fragment.AppFragment"/>
    </ViewFlipper>
</RelativeLayout>